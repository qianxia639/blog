{
  "query": {
    "bool": {
      "should": [
        {
          "match": {
            "title": "{{.title}}"
          }
        },
        {
          "range": {
            "updatedAt": {
              "gte": {{.startDate}},
              "lte": {{.endDate}}
            }
          }
        }
      ],
      "must": [
        {
          "term": {
            "userId": {
              "value": "{{.userId}}"
            }
          }
        }
      ]
    }
  },
  "sort": [
    {
      "updatedAt": {
        "order": "asc"
      }
    }
  ],
  "from": {{.from}},
  "size": {{.size}}
}